# =============================================================================
# Dados do projeto — Arquivos Grandes
# Dados brutos (raw) e gerados (bronze/silver/gold) NÃO devem ir para o git.
# Os ZIPs originais ficam em data/raw/ localmente.
# =============================================================================
data/raw/
data/bronze/
data/silver/
data/gold/

# Mantém os diretórios no git com .gitkeep
!data/raw/.gitkeep
!data/bronze/.gitkeep
!data/silver/.gitkeep
!data/gold/.gitkeep

